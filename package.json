{
  "name": "gpu-rental-platform",
  "version": "1.0.0",
  "description": "RUNPOD-like GPU rental platform - rent your RTX A4500 to anyone",
  "main": "server/index.js",
  "scripts": {
    "start":        "node server/index.js",
    "dev":          "nodemon server/index.js",
    "setup":        "node server/db/migrations.js",
    "migrate:sf":   "node scripts/migrate_sf_columns.js",
    "check":        "node check_status.js",
    "check:sf":     "node check_status.js --sf-only",
    "check:full":   "node check_status.js --full",
    "check:json":   "node check_status.js --json",
    "check:api":    "powershell -ExecutionPolicy Bypass -File scripts/check_api.ps1",
    "check:api:sf": "powershell -ExecutionPolicy Bypass -File scripts/check_api.ps1 -sf",
    "check:nodes":  "node -e \"const {getDb}=require('./server/db/database');const db=getDb();const n=db.prepare('SELECT id,hostname,status,last_seen FROM sf_nodes').all();console.table(n)\"",
    "logs":         "tail -f server/logs/app.log",
    "backup":       "node -e \"require('./server/services/backup').runBackupNow()\"",
    "agent":        "node provider/agent.js",
    "agent:dev":    "node provider/agent.js --server http://localhost:3000"
  },
  "dependencies": {
    "@stripe/stripe-js": "^8.9.0",
    "archiver": "^6.0.1",
    "bcryptjs": "^2.4.3",
    "compression": "^1.8.1",
    "cors": "^2.8.5",
    "dotenv": "^16.4.1",
    "express": "^4.18.2",
    "express-rate-limit": "^7.2.0",
    "helmet": "^7.2.0",
    "jsonwebtoken": "^9.0.2",
    "multer": "^2.0.0",
    "node-cron": "^3.0.3",
    "node-pty": "^1.1.0",
    "nodemailer": "^8.0.1",
    "socket.io": "^4.7.2",
    "sql.js": "^1.12.0",
    "stripe": "^20.4.0",
    "uuid": "^9.0.1"
  },
  "devDependencies": {
    "nodemon": "^3.0.3"
  }
}
